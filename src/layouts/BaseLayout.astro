---
import LanguageSelector from '../components/LanguageSelector.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
}

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Helper for localized URLs - English has no prefix
const getUrl = (path: string) => currentLang === 'en' ? path : `/${currentLang}${path}`;

// Prepare translations for client-side injection
const translations = {
  search: {
    placeholder: t('search.placeholder'),
    popular: t('search.popular'),
    service: {
      unavailable: t('search.service.unavailable')
    }
  },
  ui: {
    author: t('ui.author'),
    close: t('ui.close'),
    loading: t('ui.loading'),
    no: {
      results: t('ui.no.results')
    },
    search: {
      init: {
        failed: t('ui.search.init.failed')
      },
      exec: {
        failed: t('ui.search.exec.failed')
      }
    },
    service: {
      error: t('ui.service.error')
    }
  },
  book: {
    author: t('ui.author')
  },
  subject: {
    economics: t('subject.economics'),
    law: t('subject.law'),
    mathematics: t('subject.mathematics'),
    physics: t('subject.physics'),
    chemistry: t('subject.chemistry'),
    biology: t('subject.biology'),
    'computer-science': t('subject.computer-science'),
    psychology: t('subject.psychology'),
    sociology: t('subject.sociology'),
    philosophy: t('subject.philosophy'),
    history: t('subject.history'),
    literature: t('subject.literature'),
    linguistics: t('subject.linguistics'),
    'political-science': t('subject.political-science'),
    geography: t('subject.geography'),
    anthropology: t('subject.anthropology'),
    education: t('subject.education'),
    medicine: t('subject.medicine'),
    engineering: t('subject.engineering'),
    business: t('subject.business'),
    art: t('subject.art')
  }
};

const { 
  title, 
  description = t('site.description'), 
  image = "/og-image.svg",
  canonical,
  noindex = false
} = Astro.props;

const siteTitle = t('site.title');
const fullTitle = title === siteTitle ? title : `${title} - ${siteTitle}`;
const siteUrl = "https://unireadinglist.com";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

// Google Analytics ID - only from environment variable
const GA_ID = import.meta.env.GOOGLE_ANALYTICS_ID;

// Set language attribute
const langAttr = currentLang === 'zh-cn' ? 'zh-CN' : 
                 currentLang === 'zh-tw' ? 'zh-TW' : 
                 currentLang;
---

<!DOCTYPE html>
<html lang={langAttr}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- SEO Meta Tags -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, siteUrl).toString()} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteTitle} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@unireadinglist" />
  <meta name="twitter:creator" content="@unireadinglist" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, siteUrl).toString()} />
  <meta name="twitter:image:alt" content={fullTitle} />
  
  <!-- Additional SEO Meta Tags -->
  <meta name="author" content={t('site.title')} />
  <meta name="theme-color" content="#3B82F6" />
  <meta name="msapplication-TileColor" content="#3B82F6" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="format-detection" content="telephone=no" />

  <!-- Google AdSense -->
  <meta name="google-adsense-account" content="ca-pub-2079107911432321" />
  
  <!-- Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": t('site.title'),
      "url": "https://unireadinglist.com",
      "description": t('site.subtitle'),
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://unireadinglist.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  </script>
  
  <!-- Google Analytics - only load if GA_ID is configured -->
  {GA_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GA_ID);
      </script>
    </>
  )}
  
  <!-- AdSense -->
  <script
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2079107911432321"
    crossorigin="anonymous"
  ></script>
  
  <!-- Prevent FOUC (Flash of Unstyled Content) -->
  <style>
    /* Hide content until CSS is loaded */
    body { opacity: 0; transition: opacity 0.1s ease; }
    body.loaded { opacity: 1; }
  </style>
  
  <!-- Preload Critical Resources -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="min-h-screen bg-gray-50 font-sans">
  <!-- Inject translations for client-side JavaScript -->
  <script define:vars={{ translations }}>
    window.translations = translations;
    window.currentLang = window.location.pathname.split('/')[1] || 'en';
  </script>
  <!-- Header -->
  <header class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <div class="flex items-center">
          <a href="/" class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-xl font-bold text-gray-900">
                <span class="hidden sm:inline">{t('site.title')}</span>
                <span class="sm:hidden">{t('ui.mobile.logo')}</span>
              </span>
              <span class="hidden sm:block text-xs text-gray-500">{t('site.subtitle')}</span>
            </div>
          </a>
        </div>

        <!-- Center Navigation (Desktop only) -->
        <nav class="hidden lg:flex items-center space-x-8">
          <a href={getUrl('/')} class="text-gray-700 hover:text-blue-600 transition-colors">{t('nav.home')}</a>
          <a href={getUrl('/subjects')} class="text-gray-700 hover:text-blue-600 transition-colors">{t('nav.all')}</a>
          <a href={getUrl('/about')} class="text-gray-700 hover:text-blue-600 transition-colors">{t('nav.about')}</a>
        </nav>
        
        <!-- Right Side: Search + Language + Mobile Menu -->
        <div class="flex items-center space-x-4">
          <!-- Search Section -->
          <div class="flex items-center">
            <!-- Desktop Search Bar -->
            <button 
              id="search-trigger-btn"
              class="hidden md:flex items-center space-x-2 bg-gray-100 hover:bg-gray-200 px-3 py-2 rounded-lg transition-colors min-w-[200px] text-left"
              aria-label={t('nav.search')}
            >
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span class="text-sm text-gray-500">{t('nav.search')}...</span>
              <span class="ml-auto text-xs text-gray-400">⌘K</span>
            </button>

            <!-- Mobile Search Icon -->
            <button 
              id="search-trigger-btn-mobile"
              class="md:hidden p-3 rounded-md text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center"
              aria-label={t('nav.search')}
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </div>

          <!-- Language Selector (Desktop) -->
          <div class="hidden md:block">
            <LanguageSelector />
          </div>
          
          <!-- Language Selector (Mobile - Globe Icon) -->
          <div class="md:hidden">
            <LanguageSelector mobile={true} />
          </div>
          
          <!-- Mobile Menu Button -->
          <button 
            id="mobile-menu-button"
            class="lg:hidden p-3 rounded-md text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center"
            aria-label={t('ui.open.menu')}
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden lg:hidden pb-4 relative">
        <div class="absolute right-0 top-0 bg-white shadow-lg rounded-lg border border-gray-200 min-w-[160px] py-2 z-10">
          <a href={getUrl('/')} class="block px-4 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors">{t('nav.home')}</a>
          <a href={getUrl('/subjects')} class="block px-4 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors">{t('nav.all')}</a>
          <a href={getUrl('/about')} class="block px-4 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors">{t('nav.about')}</a>
        </div>
      </div>
    </div>
  </header>

  <!-- 搜索模态框 -->
  <div id="search-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden">
    <div class="flex items-start justify-center min-h-screen pt-16 px-4">
      <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full max-h-96 overflow-hidden">
        <!-- 搜索框 -->
        <div class="p-4 border-b border-gray-200">
          <div class="relative">
            <input 
              type="text" 
              id="modal-search-input"
              placeholder={t('search.placeholder')}
              class="w-full p-3 pl-10 pr-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              aria-label={t('search.placeholder')}
              aria-describedby="modal-search-results"
              autocomplete="off"
              autofocus
            />
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <button 
              id="close-search-modal"
              class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600"
              aria-label={t('ui.close')}
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
        
        <!-- 搜索结果 -->
        <div id="modal-search-results" class="max-h-80 overflow-y-auto" role="region" aria-live="polite" aria-label={t('search.results')}>
          <div id="modal-search-loading" class="hidden p-4 text-center text-gray-500">
            <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-600 mx-auto mb-2"></div>
            {t('ui.loading')}
          </div>
          <div id="modal-search-content"></div>
          <div id="modal-search-empty" class="hidden p-8 text-center text-gray-500">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p>{t('ui.no.results')}</p>
          </div>
          
          <!-- 默认状态：热门搜索 -->
          <div id="modal-search-default" class="p-4">
            <h3 class="text-sm font-medium text-gray-900 mb-3">{t('search.popular')}</h3>
            <div class="flex flex-wrap gap-2">
              <button class="modal-search-suggestion px-4 py-3 sm:px-3 sm:py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-sm text-gray-700 transition-colors min-h-[44px] sm:min-h-[32px] flex items-center justify-center" data-query={t('search.popular.economics')}>
                {t('search.popular.economics')}
              </button>
              <button class="modal-search-suggestion px-4 py-3 sm:px-3 sm:py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-sm text-gray-700 transition-colors min-h-[44px] sm:min-h-[32px] flex items-center justify-center" data-query={t('search.popular.law')}>
                {t('search.popular.law')}
              </button>
              <button class="modal-search-suggestion px-4 py-3 sm:px-3 sm:py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-sm text-gray-700 transition-colors min-h-[44px] sm:min-h-[32px] flex items-center justify-center" data-query={t('search.popular.math')}>
                {t('search.popular.math')}
              </button>
              <button class="modal-search-suggestion px-4 py-3 sm:px-3 sm:py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-sm text-gray-700 transition-colors min-h-[44px] sm:min-h-[32px] flex items-center justify-center" data-query={t('search.popular.politics')}>
                {t('search.popular.politics')}
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
      <!-- Features Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('footer.professional')}</h3>
          <p class="text-sm text-gray-300">{t('footer.professional.desc')}</p>
        </div>
        
        <div class="text-center">
          <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('footer.search')}</h3>
          <p class="text-sm text-gray-300">{t('footer.search.desc')}</p>
        </div>
        
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-600 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{t('footer.classification')}</h3>
          <p class="text-sm text-gray-300">{t('footer.classification.desc')}</p>
        </div>
      </div>
      
      <!-- Bottom Section -->
      <div class="border-t border-gray-700 pt-6">
        <div class="flex flex-col sm:flex-row justify-between items-center">
          <p class="text-xs text-gray-400 mb-3 sm:mb-0">
            {t('footer.copyright')}
          </p>
          <div class="flex space-x-4">
            <a href={getUrl('/')} class="text-gray-300 hover:text-white transition-colors text-xs">{t('nav.home')}</a>
            <a href={getUrl('/subjects')} class="text-gray-300 hover:text-white transition-colors text-xs">{t('nav.all')}</a>
            <a href={getUrl('/about')} class="text-gray-300 hover:text-white transition-colors text-xs">{t('nav.about')}</a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- Mobile Menu & Search Modal Script -->
  <script>
    let searchData = [];
    let fuse = null;

    document.addEventListener('DOMContentLoaded', async () => {
      // Mobile menu logic
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      
      if (mobileMenuButton && mobileMenu) {
        mobileMenuButton.addEventListener('click', (e) => {
          e.stopPropagation();
          mobileMenu.classList.toggle('hidden');
        });

        // Close mobile menu when clicking outside, but not on language selector
        document.addEventListener('click', (event) => {
          const target = event.target as HTMLElement;
          const isLanguageSelector = target.closest('#language-menu-button') || target.closest('#language-menu');
          const isMobileMenu = target.closest('#mobile-menu') || target.closest('#mobile-menu-button');
          
          if (!isMobileMenu && !isLanguageSelector && !mobileMenu.classList.contains('hidden')) {
            mobileMenu.classList.add('hidden');
          }
        });

        // Prevent mobile menu from closing when clicking inside it
        mobileMenu.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          // Check if clicking on a navigation link (not language selector or its children)
          const isNavLink = target.tagName === 'A' && 
                           !target.closest('#language-menu-button') && 
                           !target.closest('#language-menu');
          
          if (isNavLink) {
            mobileMenu.classList.add('hidden');
          }
        });
      }

      // Search modal logic
      const searchModal = document.getElementById('search-modal');
      const searchTriggerBtn = document.getElementById('search-trigger-btn');
      const searchTriggerBtnMobile = document.getElementById('search-trigger-btn-mobile');
      const closeSearchModal = document.getElementById('close-search-modal');
      const modalSearchInput = document.getElementById('modal-search-input');

      // Initialize search data lazily
      async function initializeSearch() {
        if (fuse) return; // Already initialized
        
        try {
          const [fuseModule, searchResponse] = await Promise.all([
            import('fuse.js'),
            fetch('/api/search.json')
          ]);
          
          const Fuse = fuseModule.default;
          const allSearchData = await searchResponse.json();
          
          // 只保留当前语言的书籍数据
          searchData = allSearchData.filter(book => book.lang === window.currentLang);
          
          fuse = new Fuse(searchData, {
            keys: ['title', 'author', 'category', 'tags', 'description'],
            threshold: 0.3,
            includeScore: true,
            includeMatches: true
          });
        } catch (error) {
          console.error(window.translations?.ui?.search?.init?.failed || 'Search initialization failed:', error);
          // 显示错误状态
          if (modalSearchInput) {
            modalSearchInput.placeholder = window.translations?.search?.service?.unavailable;
            modalSearchInput.disabled = true;
          }
        }
      }

      // Open search modal
      async function openSearchModal() {
        if (searchModal) {
          // Initialize search when modal is first opened
          await initializeSearch();
          
          searchModal.classList.remove('hidden');
          setTimeout(() => {
            if (modalSearchInput) {
              modalSearchInput.focus();
            }
          }, 100);
          // Close mobile menu if open
          if (mobileMenu) {
            mobileMenu.classList.add('hidden');
          }
        }
      }

      // Close search modal
      function closeSearchModalFn() {
        if (searchModal) {
          searchModal.classList.add('hidden');
          resetSearchModal();
        }
      }

      // Reset search modal to default state
      function resetSearchModal() {
        if (modalSearchInput) {
          modalSearchInput.value = '';
        }
        const modalSearchDefault = document.getElementById('modal-search-default');
        const modalSearchContent = document.getElementById('modal-search-content');
        const modalSearchEmpty = document.getElementById('modal-search-empty');
        const modalSearchLoading = document.getElementById('modal-search-loading');
        
        if (modalSearchDefault) modalSearchDefault.classList.remove('hidden');
        if (modalSearchContent) modalSearchContent.innerHTML = '';
        if (modalSearchEmpty) modalSearchEmpty.classList.add('hidden');
        if (modalSearchLoading) modalSearchLoading.classList.add('hidden');
      }

      // Perform search
      function performModalSearch(query) {
        if (!fuse || query.length < 2) {
          resetSearchModal();
          return;
        }

        const modalSearchDefault = document.getElementById('modal-search-default');
        const modalSearchLoading = document.getElementById('modal-search-loading');
        const modalSearchContent = document.getElementById('modal-search-content');
        const modalSearchEmpty = document.getElementById('modal-search-empty');
        
        // Hide default, show loading
        if (modalSearchDefault) modalSearchDefault.classList.add('hidden');
        if (modalSearchLoading) modalSearchLoading.classList.remove('hidden');
        if (modalSearchEmpty) modalSearchEmpty.classList.add('hidden');

        setTimeout(() => {
          try {
            const searchResults = fuse.search(query);
            
            // 根据 original_title 去重
            const seen = new Set();
            const results = searchResults.filter(result => {
              const originalTitle = result.item.original_title || result.item.title;
              if (seen.has(originalTitle)) {
                return false;
              }
              seen.add(originalTitle);
              return true;
            }).slice(0, 6);
            if (modalSearchLoading) modalSearchLoading.classList.add('hidden');
            
            if (results.length === 0) {
              if (modalSearchEmpty) modalSearchEmpty.classList.remove('hidden');
              if (modalSearchContent) modalSearchContent.innerHTML = '';
            } else {
              if (modalSearchEmpty) modalSearchEmpty.classList.add('hidden');
              displayModalResults(results);
            }
          } catch (error) {
            console.error(window.translations?.ui?.search?.exec?.failed || 'Search execution failed:', error);
            if (modalSearchLoading) modalSearchLoading.classList.add('hidden');
            if (modalSearchEmpty) {
              modalSearchEmpty.innerHTML = `<div class="p-4 text-center text-red-500">${window.translations?.search?.service?.unavailable || window.translations?.ui?.service?.error || 'Service temporarily unavailable'}</div>`;
              modalSearchEmpty.classList.remove('hidden');
            }
          }
        }, 200);
      }

      // Display search results in modal
      function displayModalResults(results) {
        const modalSearchContent = document.getElementById('modal-search-content');
        if (!modalSearchContent) return;

        modalSearchContent.innerHTML = results.map(result => {
          const item = result.item;
          return `
            <a href="${window.currentLang === 'en' ? '' : '/' + window.currentLang}/subjects/${item.category}/${item.slug.split('/').slice(1).join('/') || item.slug.split('/').pop()}" class="block p-4 hover:bg-gray-50 transition-colors border-b border-gray-100">
              <div class="flex items-start space-x-3">
                ${item.cover ? 
                  `<img src="${item.cover}" alt="${item.title}" class="w-12 h-16 object-cover rounded shadow-sm flex-shrink-0" />` :
                  `<div class="w-12 h-16 bg-gray-200 rounded flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                    </svg>
                  </div>`
                }
                <div class="flex-1 min-w-0">
                  <h4 class="text-sm font-medium text-gray-900 mb-1 line-clamp-2">
                    ${item.title}
                  </h4>
                  <p class="text-xs text-gray-600 mb-1">${window.translations?.ui?.author || 'Author'}: ${item.author}</p>
                  <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      ${window.translations?.subject?.[item.category] || item.category}
                    </span>
                    ${item.rating ? `
                      <div class="flex items-center">
                        <span class="text-yellow-400 text-xs">★</span>
                        <span class="ml-1 text-xs text-gray-600">${item.rating}</span>
                      </div>
                    ` : ''}
                  </div>
                </div>
              </div>
            </a>
          `;
        }).join('');
      }

      // Event listeners
      if (searchTriggerBtn) {
        searchTriggerBtn.addEventListener('click', openSearchModal);
      }
      
      if (searchTriggerBtnMobile) {
        searchTriggerBtnMobile.addEventListener('click', openSearchModal);
      }
      
      if (closeSearchModal) {
        closeSearchModal.addEventListener('click', closeSearchModalFn);
      }

      // Close modal when clicking outside
      if (searchModal) {
        searchModal.addEventListener('click', (e) => {
          if (e.target === searchModal) {
            closeSearchModalFn();
          }
        });
      }

      // Search input event
      if (modalSearchInput) {
        let searchTimeout;
        modalSearchInput.addEventListener('input', (e) => {
          const query = e.target.value.trim();
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(() => {
            performModalSearch(query);
          }, 300);
        });
      }

      // Search suggestions
      const modalSearchSuggestions = document.querySelectorAll('.modal-search-suggestion');
      modalSearchSuggestions.forEach(suggestion => {
        suggestion.addEventListener('click', () => {
          const query = suggestion.getAttribute('data-query');
          if (query && modalSearchInput) {
            modalSearchInput.value = query;
            performModalSearch(query);
          }
        });
      });

      // Keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        // Open search with Ctrl+K or Cmd+K
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearchModal();
        }
        
        // Close search with Escape
        if (e.key === 'Escape' && searchModal && !searchModal.classList.contains('hidden')) {
          closeSearchModalFn();
        }
      });

      // Scroll to top on page navigation
      // This ensures pages always start at the top instead of remembering scroll position
      window.scrollTo(0, 0);
      
      // Show content after everything is loaded to prevent FOUC
      document.body.classList.add('loaded');
    });
  </script>
</body>
</html>
