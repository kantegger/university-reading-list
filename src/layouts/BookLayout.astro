---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import {
  getLangFromUrl,
  useTranslations,
  getSubjectTranslationKey,
  translateTag,
} from '../i18n/utils';

export interface Props {
  title?: string;
  original_title?: string;
  author?: string;
  description?: string;
  category?: string;
  isbn?: string;
  publisher?: string;
  year?: number;
  amazonLink?: string;
  price?: string;
  rating?: number;
  tags?: string[];
  cover?: string;
  difficulty?: 'beginner' | 'intermediate' | 'advanced';
  level?: 'undergraduate' | 'graduate' | 'advanced';
  book?: any; // For passing entire book object
}

// Handle both individual props and book object
const props = Astro.props as Props;
const bookData = props.book ? props.book.data : props;

// Get current language and translations
const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Destructure with type safety and default values
const bookProps = bookData as Props;
const {
  title = '',
  author = '',
  description = '',
  category = '',
  isbn = '',
  publisher = '',
  year,
  price = '',
  rating,
  cover = '',
  difficulty,
  level,
  tags = [],
  original_title = '',
  amazonLink = '',
} = bookProps;

const difficultyColors = {
  beginner: 'bg-green-100 text-green-800',
  intermediate: 'bg-yellow-100 text-yellow-800',
  advanced: 'bg-red-100 text-red-800',
};

const levelColors = {
  undergraduate: 'bg-blue-100 text-blue-800',
  graduate: 'bg-purple-100 text-purple-800',
  advanced: 'bg-red-100 text-red-800',
};

// Get localized category, difficulty and level names
const subjectKey = getSubjectTranslationKey(category);
const categoryName = t(subjectKey);

// Type-safe translations with fallback
const difficultyName = difficulty ? t(`difficulty.${difficulty}` as const) : '';
const levelName = level ? t(`level.${level}` as const) : '';

const pageTitle = `${title} - ${author}`;
const pageDescription = `${description} | ${categoryName} ${t('book.textbook.recommendation')}`;

// 面包屑导航
const breadcrumbs = [
  { name: t('nav.home'), href: `/${currentLang}` },
  { name: t('nav.subjects'), href: `/${currentLang}/subjects` },
  { name: categoryName, href: `/${currentLang}/subjects/${category}` },
  { name: title, href: '' },
];

// 结构化数据
const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: title,
  author: {
    '@type': 'Person',
    name: author,
  },
  description: description,
  isbn: isbn,
  publisher: publisher
    ? {
        '@type': 'Organization',
        name: publisher,
      }
    : undefined,
  datePublished: year?.toString(),
  aggregateRating: rating
    ? {
        '@type': 'AggregateRating',
        ratingValue: rating,
        bestRating: 5,
      }
    : undefined,
  offers: amazonLink
    ? {
        '@type': 'Offer',
        url: amazonLink,
        price: price?.replace(/[^\d.]/g, ''),
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
      }
    : undefined,
};
---

<BaseLayout title={pageTitle} description={pageDescription} image={cover}>
  <!-- 结构化数据 -->
  <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />

  <script>
    // 确保页面加载时滚动到顶部
    if (typeof window !== 'undefined') {
      window.addEventListener('load', () => {
        window.scrollTo(0, 0);
      });
    }
  </script>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 面包屑导航 -->
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center">
        {
          breadcrumbs.map((crumb, index) => (
            <li class="inline-flex items-center">
              {index > 0 && (
                <svg class="w-4 h-4 text-gray-400 mx-2" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              {index === breadcrumbs.length - 1 ? (
                <span class="text-sm font-medium text-gray-500">{crumb.name}</span>
              ) : (
                <a
                  href={crumb.href}
                  class="text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors"
                >
                  {crumb.name}
                </a>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <!-- 主内容区域 -->
      <div class="lg:col-span-8">
        <!-- 书籍基本信息 -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
          <div class="md:flex md:space-x-6">
            <!-- 书籍封面 -->
            <div class="flex-shrink-0 mb-6 md:mb-0">
              {
                cover ? (
                  <Image
                    src={cover}
                    alt={`${title} 封面`}
                    width={192}
                    height={288}
                    class="w-48 h-72 object-cover rounded-lg shadow-md mx-auto md:mx-0"
                    loading="eager"
                  />
                ) : (
                  <div class="w-48 h-72 bg-gray-200 rounded-lg flex items-center justify-center mx-auto md:mx-0">
                    <svg class="w-16 h-16 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                )
              }
            </div>

            <!-- 书籍详细信息 -->
            <div class="flex-1">
              <h1 class="text-3xl font-bold text-gray-900 mb-4">{title}</h1>
              <div class="space-y-3 mb-6">
                {
                  original_title && currentLang !== 'en' && (
                    <p class="text-sm text-gray-600">
                      <span class="font-medium">{t('book.original.title')}:</span> {original_title}
                    </p>
                  )
                }
                <p class="text-lg text-gray-700">
                  <span class="font-medium">{t('book.author')}:</span>
                  {author}
                </p>
                {description && <p class="text-gray-600 italic leading-relaxed">{description}</p>}
              </div>

              <!-- 标签和评级 -->
              <div class="flex flex-wrap items-center gap-3 mb-6">
                <span
                  class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800"
                >
                  {categoryName}
                </span>
                {
                  difficulty && (
                    <span
                      class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${difficultyColors[difficulty]}`}
                    >
                      {difficultyName}
                    </span>
                  )
                }
                {
                  level && levelName && (
                    <span
                      class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${levelColors[level as keyof typeof levelColors]}`}
                    >
                      {levelName}
                    </span>
                  )
                }
              </div>

              <!-- 标签云 -->
              {
                tags.length > 0 && (
                  <div class="mb-6">
                    <div class="flex flex-wrap gap-2">
                      {tags.map((tag: string) => (
                        <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-gray-100 text-gray-700">
                          {translateTag(tag, currentLang)}
                        </span>
                      ))}
                    </div>
                  </div>
                )
              }
            </div>
          </div>
        </div>

        <!-- Amazon 购买链接 -->
        <div class="mb-8">
          <AffiliateLink
            amazonUrl={amazonLink}
            title={title}
            original_title={original_title}
            author={author}
            price={price}
            isbn={isbn}
          />
        </div>

        <!-- 书籍详细内容 -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>
        </div>
      </div>

      <!-- 侧边栏 -->
      <div class="mt-12 lg:mt-0 lg:col-span-4">
        <div class="sticky top-8 space-y-8">
          <!-- 快速信息 -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">{t('book.information')}</h3>
            <dl class="space-y-3">
              <div>
                <dt class="text-sm font-medium text-gray-500">{t('book.category')}</dt>
                <dd class="text-sm text-gray-900">{categoryName}</dd>
              </div>
              {
                level && levelName && (
                  <div>
                    <dt class="text-sm font-medium text-gray-500">{t('book.level')}</dt>
                    <dd class="text-sm text-gray-900">{levelName}</dd>
                  </div>
                )
              }
              {
                publisher && (
                  <div>
                    <dt class="text-sm font-medium text-gray-500">{t('book.publisher')}</dt>
                    <dd class="text-sm text-gray-900">{publisher}</dd>
                  </div>
                )
              }
              {
                year && (
                  <div>
                    <dt class="text-sm font-medium text-gray-500">{t('book.year')}</dt>
                    <dd class="text-sm text-gray-900">{year}</dd>
                  </div>
                )
              }
              {
                isbn && (
                  <div>
                    <dt class="text-sm font-medium text-gray-500">ISBN</dt>
                    <dd class="text-sm text-gray-900 font-mono">{isbn}</dd>
                  </div>
                )
              }
            </dl>
          </div>

          <!-- 相关推荐 -->
          {
            /* <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">{t('book.related.recommendations')}</h3>
            <div class="space-y-4">
              <div class="text-sm text-gray-600 text-center py-8">
                {t('book.related.coming.soon')}
              </div>
            </div>
          </div> */
          }

          <!-- Support This Project -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">{t('book.support.title')}</h3>
            <p class="text-sm text-gray-600 mb-4">{t('book.support.description')}</p>
            <a
              href="https://buymeacoffee.com/yuhao83f"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center w-full bg-yellow-400 hover:bg-yellow-500 text-black px-6 py-3 rounded-lg font-medium transition-colors shadow-sm hover:shadow-md"
            >
              <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M18.5,3H6C4.89,3 4,3.89 4,5V19A2,2 0 0,0 6,21H14C15.11,21 16,20.11 16,19V16H18.5C20.43,16 22,14.43 22,12.5C22,10.57 20.43,9 18.5,9H16V5C16,3.89 15.11,3 14,3H6M6,5H14V7.5H14V9H14V14H14V16H6V5M18.5,11C19.33,11 20,11.67 20,12.5C20,13.33 19.33,14 18.5,14H16V11H18.5Z"
                ></path>
              </svg>
              {t('book.support.button')}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 页面底部广告 -->
  <div class="bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"></div>
  </div>
</BaseLayout>

<style>
  .prose {
    color: #374151;
  }

  .prose h1 {
    color: #111827;
    font-weight: 600;
    font-size: 1.875rem; /* 30px, equivalent to text-3xl */
    line-height: 2.25rem;
  }

  .prose h2 {
    color: #111827;
    font-weight: 600;
    font-size: 1.5rem; /* 24px, equivalent to text-2xl */
    line-height: 2rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose h3 {
    color: #111827;
    font-weight: 600;
    font-size: 1.25rem; /* 20px, equivalent to text-xl */
    line-height: 1.75rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose h4 {
    color: #111827;
    font-weight: 600;
    font-size: 1.125rem; /* 18px, equivalent to text-lg */
    line-height: 1.75rem;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .prose h5 {
    color: #111827;
    font-weight: 600;
    font-size: 1rem; /* 16px, equivalent to text-base */
    line-height: 1.5rem;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .prose h6 {
    color: #111827;
    font-weight: 600;
    font-size: 0.875rem; /* 14px, equivalent to text-sm */
    line-height: 1.25rem;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .prose a {
    color: #2563eb;
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  .prose p {
    margin-bottom: 1.25em;
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1.25em;
  }

  .prose li {
    margin-bottom: 0.5em;
  }

  .prose blockquote {
    font-style: italic;
    border-left: 4px solid #e5e7eb;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #6b7280;
    quotes: none;
  }

  .prose blockquote:before,
  .prose blockquote:after {
    content: none !important;
    quotes: none !important;
  }

  .prose blockquote p:before,
  .prose blockquote p:after {
    content: none !important;
    quotes: none !important;
  }

  .prose blockquote * {
    quotes: none;
  }

  .prose blockquote *:before,
  .prose blockquote *:after {
    content: none !important;
  }
</style>
