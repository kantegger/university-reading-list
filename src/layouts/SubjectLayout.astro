---
import BaseLayout from './BaseLayout.astro';
import SubjectNav from '../components/SubjectNav.astro';

export interface Props {
  title: string;
  description?: string;
  category: string;
  breadcrumbs?: Array<{ name: string; href: string }>;
}

const { title, description, category, breadcrumbs = [] } = Astro.props;

const categoryNames = {
  economics: '经济学',
  law: '法学',
  mathematics: '数学',
  'political-science': '政治学',
  sociology: '社会学',
  philosophy: '哲学',
};

const categoryName = categoryNames[category as keyof typeof categoryNames] || category;
const pageTitle = `${categoryName} - ${title}`;
const pageDescription = description || `${categoryName}专业推荐书单，包含经典教材和参考书籍`;

// 默认面包屑导航
const defaultBreadcrumbs = [
  { name: '首页', href: '/' },
  { name: '学科分类', href: '/subjects' },
  { name: categoryName, href: `/subjects/${category}` },
];

const allBreadcrumbs = breadcrumbs.length > 0 ? breadcrumbs : defaultBreadcrumbs;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- 页面顶部广告 -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 面包屑导航 -->
    <nav class="flex mb-8" aria-label="面包屑导航">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        {
          allBreadcrumbs.map((crumb, index) => (
            <li class="inline-flex items-center">
              {index > 0 && (
                <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              {index === allBreadcrumbs.length - 1 ? (
                <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2">{crumb.name}</span>
              ) : (
                <a
                  href={crumb.href}
                  class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 transition-colors"
                >
                  {crumb.name}
                </a>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <!-- 主内容区域 -->
      <div class="lg:col-span-8">
        <!-- 页面标题和描述 -->
        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-4">{title}</h1>
          {description && <p class="text-lg text-gray-600 leading-relaxed">{description}</p>}
        </div>

        <!-- 内容中间广告 -->
        <div class="mb-8"></div>

        <!-- 主要内容插槽 -->
        <div class="prose prose-lg max-w-none">
          <slot />
        </div>
      </div>

      <!-- 侧边栏 -->
      <div class="mt-12 lg:mt-0 lg:col-span-4">
        <div class="sticky top-8 space-y-8">
          <!-- 学科导航 -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">学科分类</h3>
            <SubjectNav currentCategory={category} />
          </div>

          <!-- 侧边栏广告 -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6"></div>

          <!-- 相关推荐 -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">相关推荐</h3>
            <div class="space-y-4">
              <div class="flex items-center space-x-3">
                <div class="w-12 h-16 bg-gray-200 rounded flex-shrink-0"></div>
                <div class="flex-1 min-w-0">
                  <h4 class="text-sm font-medium text-gray-900 line-clamp-2">推荐书籍标题</h4>
                  <p class="text-xs text-gray-600">作者名称</p>
                </div>
              </div>
              <!-- 更多推荐项目可以通过插槽或数据传入 -->
            </div>
          </div>

          <!-- 热门标签 -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">热门标签</h3>
            <div class="flex flex-wrap gap-2">
              <span
                class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-blue-100 text-blue-800"
                >入门教材</span
              >
              <span
                class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-green-100 text-green-800"
                >经典著作</span
              >
              <span
                class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-yellow-100 text-yellow-800"
                >研究生</span
              >
              <span
                class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-purple-100 text-purple-800"
                >本科生</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 页面底部广告 -->
  <div class="bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"></div>
  </div>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prose {
    color: #374151;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    color: #111827;
    font-weight: 600;
  }

  .prose a {
    color: #2563eb;
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }
</style>
