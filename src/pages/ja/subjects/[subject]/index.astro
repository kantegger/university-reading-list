---
import { getAvailableSubjects, getContentBySubject, subjects } from '../../../../lib/content-utils';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BookCard from '../../../../components/BookCard.astro';
import { getLangFromUrl, useTranslations, getSubjectTranslationKey } from '../../../../i18n/utils';

export async function getStaticPaths() {
  const availableSubjects = await getAvailableSubjects('ja');

  // Generate paths for each available subject
  const paths = [];
  for (const subject of availableSubjects) {
    const books = await getContentBySubject('ja', subject);
    const subjectParam = subject.toLowerCase().replace(/\s+/g, '-');

    paths.push({
      params: { subject: subjectParam },
      props: {
        subject,
        books,
      },
    });
  }

  return paths;
}

const { subject, books } = Astro.props;
const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Get subject display name
const subjectKey = getSubjectTranslationKey(subject);
const subjectName = t(subjectKey);

const pageTitle = `${subjectName} - ${t('site.name')}`;
const pageDescription = `${subjectName}の教科書と学術リソースを閲覧し、大学生におすすめの良質な書籍。`;
---

<BaseLayout title={pageTitle} description={pageDescription} lang={currentLang}>
  <div class="min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Page Header -->
      <div class="mb-8">
        <nav class="flex mb-4" aria-label="パンくずナビ">
          <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
              <a
                href={`/${currentLang}`}
                class="text-gray-700 hover:text-blue-600 transition-colors"
              >
                {t('nav.home')}
              </a>
            </li>
            <li>
              <div class="flex items-center">
                <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"></path>
                </svg>
                <a
                  href={`/${currentLang}/subjects`}
                  class="ml-1 text-gray-700 hover:text-blue-600 md:ml-2 transition-colors"
                >
                  {t('nav.subjects')}
                </a>
              </div>
            </li>
            <li>
              <div class="flex items-center">
                <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"></path>
                </svg>
                <span class="ml-1 text-gray-500 md:ml-2">{subjectName}</span>
              </div>
            </li>
          </ol>
        </nav>

        <h1 class="text-3xl font-bold text-gray-900 mb-2">{subjectName}</h1>
        <p class="text-lg text-gray-600">
          {t('subjects.description')}
          {books.length}
          {t('subjects.books.count')}
        </p>
      </div>

      <!-- Books Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {books.map((book, index) => <BookCard book={book} priority={index < 4} />)}
      </div>

      {
        books.length === 0 && (
          <div class="text-center py-12">
            <div class="text-gray-400 mb-4">
              <svg class="w-16 h-16 mx-auto" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">書籍がありません</h3>
            <p class="text-gray-600">このカテゴリにより多くの書籍を追加するよう努めています。</p>
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>
