---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<BaseLayout title={t('about.title')} description={t('about.subtitle')}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb Navigation -->
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a
            href="/zh-tw/"
            class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 transition-colors"
          >
            {t('about.breadcrumb.home')}
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2">{t('about.title')}</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Page Title -->
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{t('about.title')}</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        {t('about.subtitle')}
      </p>
    </div>

    <!-- Top Ad Space -->
    <div class="mb-12">
      <!-- Ad content can be added here -->
    </div>

    <div class="prose prose-lg max-w-none">
      <!-- Our Mission -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">{t('about.mission')}</h2>
        <div class="bg-blue-50 rounded-lg p-8">
          <p class="text-gray-700 leading-relaxed mb-4">
            {t('about.mission.desc1')}
          </p>
          <p class="text-gray-700 leading-relaxed">
            {t('about.mission.desc2')}
          </p>
        </div>
      </section>

      <!-- Our Values -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">{t('about.values')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
              <svg
                class="w-6 h-6 text-blue-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{t('about.values.rigor')}</h3>
            <p class="text-gray-600">
              {t('about.values.rigor.desc')}
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
              <svg
                class="w-6 h-6 text-green-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{t('about.values.equity')}</h3>
            <p class="text-gray-600">
              {t('about.values.equity.desc')}
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
              <svg
                class="w-6 h-6 text-purple-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{t('about.values.innovation')}</h3>
            <p class="text-gray-600">
              {t('about.values.innovation.desc')}
            </p>
          </div>

          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
              <svg
                class="w-6 h-6 text-orange-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{t('about.values.community')}</h3>
            <p class="text-gray-600">
              {t('about.values.community.desc')}
            </p>
          </div>
        </div>
      </section>

      <!-- Middle Ad Space -->
      <div class="mb-12">
        <!-- Ad content can be added here -->
      </div>

      <!-- Our Services -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">{t('about.services')}</h2>
        <div class="space-y-6">
          <div class="border-l-4 border-blue-500 pl-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              📚 {t('about.services.selection')}
            </h3>
            <p class="text-gray-700">
              {t('about.services.selection.desc')}
            </p>
          </div>

          <div class="border-l-4 border-green-500 pl-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              🔍 {t('about.services.search')}
            </h3>
            <p class="text-gray-700">
              {t('about.services.search.desc')}
            </p>
          </div>

          <div class="border-l-4 border-purple-500 pl-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              📖 {t('about.services.details')}
            </h3>
            <p class="text-gray-700">
              {t('about.services.details.desc')}
            </p>
          </div>

          <div class="border-l-4 border-orange-500 pl-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              🛒 {t('about.services.purchase')}
            </h3>
            <p class="text-gray-700">
              {t('about.services.purchase.desc')}
            </p>
          </div>
        </div>
      </section>

      <!-- Contact Us -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">{t('about.contact')}</h2>
        <div class="bg-gray-50 rounded-lg p-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-4">
                {t('about.contact.feedback')}
              </h3>
              <p class="text-gray-700 mb-4">
                {t('about.contact.feedback.desc')}
              </p>
              <div class="space-y-2">
                <div class="flex items-center">
                  <svg
                    class="w-5 h-5 text-gray-400 mr-3"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                  <span class="text-gray-700">{t('about.contact.email')}</span>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-4">
                {t('about.contact.partnership')}
              </h3>
              <p class="text-gray-700 mb-4">
                {t('about.contact.partnership.desc')}
              </p>
              <div class="space-y-2">
                <div class="flex items-center">
                  <svg
                    class="w-5 h-5 text-gray-400 mr-3"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0H8m8 0v2a2 2 0 01-2 2H10a2 2 0 01-2-2V6"
                    ></path>
                  </svg>
                  <span class="text-gray-700">{t('about.contact.partnership.email')}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Disclaimer -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">{t('about.disclaimer')}</h2>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
          <p class="text-gray-700 text-sm leading-relaxed">
            {t('about.disclaimer.desc')}
          </p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
