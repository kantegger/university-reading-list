---
import { languages, defaultLang } from '../i18n/config';
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';

interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;
const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
---

<div class="relative inline-block text-left">
  <div>
    <button
      type="button"
      class={mobile
        ? 'p-3 rounded-md text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center'
        : 'inline-flex items-center justify-center w-full rounded-md border border-gray-300 shadow-sm px-3 py-2 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500'}
      id="language-menu-button"
      aria-expanded="false"
      aria-haspopup="true"
      aria-label={mobile ? 'Select language' : undefined}
    >
      {
        mobile ? (
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
        ) : (
          <>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
              />
            </svg>
            {languages[currentLang]}
            <svg class="-mr-1 ml-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"
              />
            </svg>
          </>
        )
      }
    </button>
  </div>

  <div
    class={mobile
      ? 'hidden origin-top-right absolute left-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none z-50'
      : 'hidden origin-top-right absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none z-50'}
    id="language-menu"
    role="menu"
    aria-orientation="vertical"
    aria-labelledby="language-menu-button"
  >
    <div class="py-1" role="none">
      {
        Object.entries(languages).map(([lang, name]) => {
          const localizedPath = getLocalizedPath(currentPath, currentLang, lang);
          const isActive = lang === currentLang;

          return (
            <a
              href={localizedPath}
              class={`
              block px-4 py-2 text-sm transition-colors focus:outline-none focus:bg-gray-100 focus:text-gray-900
              ${
                isActive
                  ? 'bg-blue-50 text-blue-700 font-medium'
                  : 'text-gray-700 hover:bg-gray-100 hover:text-gray-900'
              }
            `}
              role="menuitem"
              tabindex="-1"
            >
              <div class="flex items-center">
                <span class="mr-3">
                  {lang === 'en' && '🇺🇸'}
                  {lang === 'zh-cn' && '🇨🇳'}
                  {lang === 'zh-tw' && '🇭🇰'}
                  {lang === 'ja' && '🇯🇵'}
                </span>
                {name}
                {isActive && (
                  <svg
                    class="ml-auto w-4 h-4 text-blue-600"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                )}
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<script>
  // Enhanced keyboard navigation and click handling
  document.addEventListener('keydown', e => {
    const target = e.target as HTMLElement;
    const button = target.closest('#language-menu-button');
    const menu = document.getElementById('language-menu');

    // Handle Enter and Space on language button
    if (button && (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      button.click();
      return;
    }

    // Handle Escape key to close menu
    if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
      e.preventDefault();
      menu.classList.add('hidden');
      button?.setAttribute('aria-expanded', 'false');
      button?.focus();
      return;
    }

    // Handle Arrow keys for menu navigation
    if (menu && !menu.classList.contains('hidden')) {
      const menuItems = menu.querySelectorAll('a[role="menuitem"]');
      const currentIndex = Array.from(menuItems).findIndex(item => item === document.activeElement);

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const nextIndex = currentIndex < menuItems.length - 1 ? currentIndex + 1 : 0;
        (menuItems[nextIndex] as HTMLElement).focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const prevIndex = currentIndex > 0 ? currentIndex - 1 : menuItems.length - 1;
        (menuItems[prevIndex] as HTMLElement).focus();
      } else if (e.key === 'Home') {
        e.preventDefault();
        (menuItems[0] as HTMLElement).focus();
      } else if (e.key === 'End') {
        e.preventDefault();
        (menuItems[menuItems.length - 1] as HTMLElement).focus();
      }
    }
  });

  // Use event delegation to handle clicks
  document.addEventListener(
    'click',
    e => {
      const target = e.target as HTMLElement;

      // Check if click is on the language button or its children
      const button = target.closest('#language-menu-button');
      if (button) {
        e.preventDefault();
        e.stopPropagation();

        const menu = document.getElementById('language-menu');
        if (menu) {
          const isHidden = menu.classList.contains('hidden');

          menu.classList.toggle('hidden');
          button.setAttribute('aria-expanded', isHidden ? 'true' : 'false');

          // Focus first menu item when opening
          if (isHidden) {
            setTimeout(() => {
              const firstMenuItem = menu.querySelector('a[role="menuitem"]') as HTMLElement;
              firstMenuItem?.focus();
            }, 50);
          }

          // Create a working language menu
          if (!menu.classList.contains('hidden')) {
            // Hide the broken original menu
            menu.style.display = 'none';

            // Create a working replacement menu with proper language links
            let workingMenu = document.getElementById('working-language-menu');
            if (!workingMenu) {
              workingMenu = document.createElement('div');

              // Get current path and language info from the page
              const currentPath = window.location.pathname;
              const currentLang = document.documentElement.lang || 'en';

              // Language mapping
              const languages = {
                en: { name: 'English', flag: '🇺🇸' },
                'zh-cn': { name: '简体中文', flag: '🇨🇳' },
                'zh-tw': { name: '繁體中文', flag: '🇹🇼' },
                ja: { name: '日本語', flag: '🇯🇵' },
              };

              // Generate localized paths for each language
              const getLocalizedPath = (path, fromLang, toLang) => {
                // Remove all language prefixes from path
                let cleanPath = path
                  .replace(/^\/(en|zh-cn|zh-tw|ja)(\/|$)/, '/')
                  .replace(/\/+/g, '/');

                if (cleanPath === '' || cleanPath === '//') cleanPath = '/';

                // English has no prefix
                if (toLang === 'en') {
                  return cleanPath;
                } else {
                  return '/' + toLang + (cleanPath === '/' ? '' : cleanPath);
                }
              };

              // Build menu HTML
              let menuHTML = '<div style="padding: 4px 0;">';
              Object.entries(languages).forEach(([lang, info], index) => {
                const localizedPath = getLocalizedPath(currentPath, currentLang, lang);
                const isActive = lang === currentLang;
                const borderStyle =
                  index < Object.keys(languages).length - 1
                    ? 'border-bottom: 1px solid #e5e7eb;'
                    : '';
                const textStyle = isActive
                  ? 'color: #1d4ed8; font-weight: 600;'
                  : 'color: #374151;';

                menuHTML += `
                <a href="${localizedPath}" style="display: block; padding: 8px 16px; ${textStyle} text-decoration: none; ${borderStyle}">
                  ${info.flag} ${info.name}
                </a>
              `;
              });
              menuHTML += '</div>';

              workingMenu.innerHTML = menuHTML;
              workingMenu.style.cssText = `
              position: absolute !important;
              top: 100% !important;
              right: 0 !important;
              min-width: 140px !important;
              max-width: 200px !important;
              width: max-content !important;
              margin-top: 8px !important;
              background-color: white !important;
              border-radius: 6px !important;
              box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
              border: 1px solid rgba(0, 0, 0, 0.05) !important;
              z-index: 50 !important;
              display: block !important;
              white-space: nowrap !important;
            `;
              workingMenu.id = 'working-language-menu';

              // Always append to the relative parent
              const parent = button.closest('.relative');
              if (parent) {
                parent.appendChild(workingMenu);
              } else {
                // If no relative parent, create one
                const wrapper = document.createElement('div');
                wrapper.style.position = 'relative';
                wrapper.style.display = 'inline-block';
                button.parentNode.insertBefore(wrapper, button);
                wrapper.appendChild(button);
                wrapper.appendChild(workingMenu);
              }

              // Add hover effects
              const links = workingMenu.querySelectorAll('a');
              links.forEach(link => {
                link.addEventListener('mouseenter', () => {
                  link.style.backgroundColor = '#f3f4f6';
                });
                link.addEventListener('mouseleave', () => {
                  link.style.backgroundColor = 'transparent';
                });
              });
            }

            workingMenu.style.display = 'block';
          } else {
            // Hide the working menu when closed
            const workingMenu = document.getElementById('working-language-menu');
            if (workingMenu) {
              workingMenu.style.display = 'none';
            }
          }
        }
        return;
      }

      // Check if click is inside the menu
      const menuClick = target.closest('#language-menu');
      if (menuClick) {
        e.stopPropagation();
        return;
      }

      // Click outside - close the menu
      const menu = document.getElementById('language-menu');
      const langButton = document.getElementById('language-menu-button');
      if (menu && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        if (langButton) {
          langButton.setAttribute('aria-expanded', 'false');
        }
      }
    },
    true
  ); // Use capture phase
</script>
