---
// Search functionality script
---

<!-- Mobile Menu & Search Modal Script -->
<script>
  let searchData = [];
  let fuse = null;

  document.addEventListener('DOMContentLoaded', async () => {
    // Mobile menu logic
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close mobile menu when clicking outside
      document.addEventListener('click', e => {
        if (!mobileMenuButton.contains(e.target) && !mobileMenu.contains(e.target)) {
          mobileMenu.classList.add('hidden');
        }
      });
    }

    // Prevent FOUC
    document.body.classList.add('loaded');

    // Search functionality
    const searchTriggerBtn = document.getElementById('search-trigger-btn');
    const searchTriggerBtnMobile = document.getElementById('search-trigger-btn-mobile');
    const searchModal = document.getElementById('search-modal');
    const closeSearchModal = document.getElementById('close-search-modal');
    const modalSearchInput = document.getElementById('modal-search-input');

    // Load search data lazily
    async function loadSearchData() {
      if (searchData.length === 0) {
        try {
          const response = await fetch('/api/search.json');
          searchData = await response.json();

          // Initialize Fuse.js
          const { default: Fuse } = await import('https://cdn.skypack.dev/fuse.js');
          fuse = new Fuse(searchData, {
            keys: ['title', 'author', 'category'],
            threshold: 0.3,
            includeScore: true,
          });
        } catch (error) {
          console.error('Failed to load search data:', error);
        }
      }
    }

    function openSearchModal() {
      if (searchModal) {
        searchModal.classList.remove('hidden');
        if (modalSearchInput) {
          modalSearchInput.focus();
        }
        loadSearchData();
      }
    }

    function closeSearchModalFn() {
      if (searchModal) {
        searchModal.classList.add('hidden');
        if (modalSearchInput) {
          modalSearchInput.value = '';
        }
        resetModalSearchState();
      }
    }

    function resetModalSearchState() {
      const modalSearchEmpty = document.getElementById('modal-search-empty');
      const modalSearchResultsList = document.getElementById('modal-search-results-list');
      const modalSearchLoading = document.getElementById('modal-search-loading');
      const modalSearchNoResults = document.getElementById('modal-search-no-results');

      if (modalSearchEmpty) modalSearchEmpty.classList.remove('hidden');
      if (modalSearchResultsList) modalSearchResultsList.classList.add('hidden');
      if (modalSearchLoading) modalSearchLoading.classList.add('hidden');
      if (modalSearchNoResults) modalSearchNoResults.classList.add('hidden');
    }

    // Perform search in modal
    async function performModalSearch(query) {
      if (!query || query.length < 2) {
        resetModalSearchState();
        return;
      }

      // Show loading state
      const modalSearchEmpty = document.getElementById('modal-search-empty');
      const modalSearchResultsList = document.getElementById('modal-search-results-list');
      const modalSearchLoading = document.getElementById('modal-search-loading');
      const modalSearchNoResults = document.getElementById('modal-search-no-results');

      if (modalSearchEmpty) modalSearchEmpty.classList.add('hidden');
      if (modalSearchResultsList) modalSearchResultsList.classList.add('hidden');
      if (modalSearchLoading) modalSearchLoading.classList.remove('hidden');
      if (modalSearchNoResults) modalSearchNoResults.classList.add('hidden');

      await loadSearchData();

      if (!fuse) {
        if (modalSearchLoading) modalSearchLoading.classList.add('hidden');
        if (modalSearchNoResults) modalSearchNoResults.classList.remove('hidden');
        return;
      }

      setTimeout(() => {
        const results = fuse.search(query).slice(0, 8);

        if (modalSearchLoading) modalSearchLoading.classList.add('hidden');

        if (results.length === 0) {
          if (modalSearchNoResults) modalSearchNoResults.classList.remove('hidden');
        } else {
          if (modalSearchResultsList) {
            modalSearchResultsList.classList.remove('hidden');
            displayModalResults(results);
          }
        }
      }, 200);
    }

    // Display search results in modal
    function displayModalResults(results) {
      const modalSearchResultsList = document.getElementById('modal-search-results-list');
      if (!modalSearchResultsList) return;

      // Get category name using translations
      function getCategoryName(category) {
        return window.translations?.subject?.[category] || category;
      }

      modalSearchResultsList.innerHTML = results
        .map(result => {
          const item = result.item;
          return `
          <a href="/subjects/${item.category}/${item.slug.split('/').slice(1).join('/') || item.slug.split('/').pop()}" class="block p-4 hover:bg-gray-50 transition-colors border-b border-gray-100">
            <div class="flex items-start space-x-3">
              ${
                item.cover
                  ? `<img src="${item.cover}" alt="${item.title}" class="w-12 h-16 object-cover rounded shadow-sm flex-shrink-0" />`
                  : `<div class="w-12 h-16 bg-gray-200 rounded flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                  </svg>
                </div>`
              }
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-medium text-gray-900 mb-1 line-clamp-2">
                  ${item.title}
                </h4>
                <p class="text-xs text-gray-600 mb-1">作者: ${item.author}</p>
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    ${getCategoryName(item.category)}
                  </span>
                  ${
                    item.rating
                      ? `
                    <div class="flex items-center">
                      <span class="text-yellow-400 text-xs">★</span>
                      <span class="ml-1 text-xs text-gray-600">${item.rating}</span>
                    </div>
                  `
                      : ''
                  }
                </div>
              </div>
            </div>
          </a>
        `;
        })
        .join('');
    }

    // Event listeners
    if (searchTriggerBtn) {
      searchTriggerBtn.addEventListener('click', openSearchModal);
    }

    if (searchTriggerBtnMobile) {
      searchTriggerBtnMobile.addEventListener('click', openSearchModal);
    }

    if (closeSearchModal) {
      closeSearchModal.addEventListener('click', closeSearchModalFn);
    }

    // Close modal when clicking outside
    if (searchModal) {
      searchModal.addEventListener('click', e => {
        if (e.target === searchModal) {
          closeSearchModalFn();
        }
      });
    }

    // Search input event
    if (modalSearchInput) {
      let searchTimeout;
      modalSearchInput.addEventListener('input', e => {
        const query = e.target.value.trim();
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          performModalSearch(query);
        }, 300);
      });
    }

    // Search suggestions
    const searchSuggestions = document.querySelectorAll('.search-suggestion');
    searchSuggestions.forEach(suggestion => {
      suggestion.addEventListener('click', () => {
        const query = suggestion.getAttribute('data-query');
        if (query && modalSearchInput) {
          modalSearchInput.value = query;
          performModalSearch(query);
        }
      });
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', e => {
      // Cmd/Ctrl + K to open search
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearchModal();
      }

      // Escape to close search modal
      if (e.key === 'Escape' && searchModal && !searchModal.classList.contains('hidden')) {
        closeSearchModalFn();
      }
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Hide content until CSS is loaded */
  body {
    opacity: 0;
    transition: opacity 0.1s ease;
  }
  body.loaded {
    opacity: 1;
  }
</style>
