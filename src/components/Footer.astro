---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<!-- Footer -->
<footer class="bg-gray-900 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="text-center">
        <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{t('footer.professional')}</h3>
        <p class="text-sm text-gray-300">{t('footer.professional.desc')}</p>
      </div>
      
      <div class="text-center">
        <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{t('footer.search')}</h3>
        <p class="text-sm text-gray-300">{t('footer.search.desc')}</p>
      </div>
      
      <div class="text-center">
        <div class="w-12 h-12 bg-purple-600 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{t('footer.classification')}</h3>
        <p class="text-sm text-gray-300">{t('footer.classification.desc')}</p>
      </div>
    </div>
    
    <!-- Bottom Section -->
    <div class="border-t border-gray-700 pt-6">
      <div class="flex flex-col sm:flex-row justify-between items-center">
        <p class="text-xs text-gray-400 mb-3 sm:mb-0">
          {t('footer.copyright')}
        </p>
        <div class="flex space-x-4">
          <a href={`/${currentLang === 'zh-cn' ? 'zh-cn' : currentLang === 'zh-tw' ? 'zh-tw' : currentLang === 'ja' ? 'ja' : 'en'}/`} class="text-gray-300 hover:text-white transition-colors text-xs">{t('nav.home')}</a>
          <a href={`/${currentLang === 'zh-cn' ? 'zh-cn' : currentLang === 'zh-tw' ? 'zh-tw' : currentLang === 'ja' ? 'ja' : 'en'}/subjects`} class="text-gray-300 hover:text-white transition-colors text-xs">{t('nav.all')}</a>
          <a href={`/${currentLang === 'zh-cn' ? 'zh-cn' : currentLang === 'zh-tw' ? 'zh-tw' : currentLang === 'ja' ? 'ja' : 'en'}/about`} class="text-gray-300 hover:text-white transition-colors text-xs">{t('nav.about')}</a>
        </div>
      </div>
    </div>
  </div>
</footer>