---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

export interface Props {
  title: string;
  original_title?: string;
  price?: string;
  isbn?: string;
  author?: string;
  className?: string;
  amazonUrl?: string;
}

const { title, original_title, price, isbn, author, className = '', amazonUrl } = Astro.props;

// Get current language and translations
const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

// Amazon affiliate configuration per region
// Set your Amazon Associates tags via environment variables or replace the placeholders below
const amazonConfig = {
  en: {
    domain: 'amazon.com',
    tag: import.meta.env.AMAZON_ASSOCIATE_TAG_US || 'your-associate-tag-us', // US Amazon
    currency: 'USD',
  },
  ja: {
    domain: 'amazon.co.jp',
    tag: import.meta.env.AMAZON_ASSOCIATE_TAG_JP || 'your-associate-tag-jp', // Japan Amazon
    currency: 'JPY',
  },
  'zh-cn': {
    domain: 'amazon.sg',
    tag: import.meta.env.AMAZON_ASSOCIATE_TAG_SG || 'your-associate-tag-sg', // Singapore Amazon
    currency: 'SGD',
  },
  'zh-tw': {
    domain: 'amazon.sg',
    tag: import.meta.env.AMAZON_ASSOCIATE_TAG_SG || 'your-associate-tag-sg', // Singapore Amazon
    currency: 'SGD',
  },
};

const config = amazonConfig[currentLang as keyof typeof amazonConfig] || amazonConfig['en'];

// Generate Amazon search URL using original_title first, then title
function generateAmazonLink(): string {
  if (amazonUrl) {
    // Use provided URL and add affiliate tag
    try {
      const urlObj = new URL(amazonUrl);
      urlObj.searchParams.set('tag', config.tag);
      return urlObj.toString();
    } catch (error) {
      return amazonUrl;
    }
  } else {
    // Use original_title if available, otherwise fall back to title
    const searchTitle = original_title || title;
    const searchQuery = `${searchTitle} ${author || ''}`.trim();
    const searchUrl = `https://${config.domain}/s`;
    const params = new URLSearchParams({
      k: searchQuery,
      tag: config.tag,
      i: 'stripbooks',
      ref: 'sr_1_1',
    });
    return `${searchUrl}?${params.toString()}`;
  }
}

const affiliateLink = generateAmazonLink();
---

<div
  class={`affiliate-box bg-gradient-to-r from-orange-50 to-yellow-50 p-4 rounded-lg border border-orange-200 ${className}`}
>
  <div class="flex items-start space-x-4">
    <!-- Amazon 图标 -->
    <div class="flex-shrink-0">
      <div
        class="w-12 h-12 bg-gradient-to-br from-orange-400 to-orange-600 rounded-lg flex items-center justify-center shadow-sm"
      >
        <!-- Amazon Logo SVG -->
        <svg
          class="w-7 h-7 text-white"
          fill="currentColor"
          viewBox="0 0 35.418 35.418"
          xmlns="http://www.w3.org/2000/svg"
        >
