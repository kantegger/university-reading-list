    "astro": "^5.12.8",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^16.3.0",
    "tailwindcss": "^3.4.17",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.35.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.35.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
