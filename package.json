{
  "name": "solar-shepherd",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:prod": "astro build --mode production",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro check",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
